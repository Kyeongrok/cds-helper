<Window x:Class="CdsHelper.Main.Themes.Views.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CdsHelper.Main.Themes.Views"
        mc:Ignorable="d"
        Title="Window2" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="Button1" TargetType="Button">
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderThickness="2">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0.0" />
                                    <GradientStop Color="Gray" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="7*" />
                                    <RowDefinition Height="3*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="8,8,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="LightGray" Offset="0.0" />
                                            <GradientStop Color="White" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Viewbox Margin="16" Stretch="Uniform">
                                        <Canvas Width="24" Height="22">
                                            <Path Fill="DodgerBlue"
                                                  Stroke="#444444"
                                                  StrokeThickness="0.5"
                                                  Data="M12 7 A4 4 0 1 0 12 15 A4 4 0 1 0 12 7 Z" />
                                            <Path Fill="Transparent"
                                                  Stroke="#444444"
                                                  StrokeThickness="0.5"
                                                  StrokeLineJoin="Round"
                                                  Data="M11 1 H13 L13.6 3.5 A8.5 8.5 0 0 1 16 4.5 L18.2 3.2 L19.8 4.8 L18.5 7 A8.5 8.5 0 0 1 19.5 9.4 L22 10 V12 L19.5 12.6 A8.5 8.5 0 0 1 18.5 15 L19.8 17.2 L18.2 18.8 L16 17.5 A8.5 8.5 0 0 1 13.6 18.5 L13 21 H11 L10.4 18.5 A8.5 8.5 0 0 1 8 17.5 L5.8 18.8 L4.2 17.2 L5.5 15 A8.5 8.5 0 0 1 4.5 12.6 L2 12 V10 L4.5 9.4 A8.5 8.5 0 0 1 5.5 7 L4.2 4.8 L5.8 3.2 L8 4.5 A8.5 8.5 0 0 1 10.4 3.5 Z" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <Border Grid.Row="1" CornerRadius="0, 0, 8, 8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#545378" Offset="0.0" />
                                            <GradientStop Color="#47494a" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter 
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                    ></ContentPresenter>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    <Style x:Key="StepButton" TargetType="Button">
        <Setter Property="Width" Value="86" />
        <Setter Property="Height" Value="62" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="4" BorderThickness="1" BorderBrush="#3A7BA8" Margin="0,0,4,4">
                        <Border.Effect>
                            <DropShadowEffect Color="#404040" BlurRadius="6" ShadowDepth="3" Direction="315" Opacity="0.5" />
                        </Border.Effect>
                        <Border CornerRadius="5" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#BDE0F3" Offset="0.0" />
                                    <GradientStop Color="#6FB2D8" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#7FC3E6" Offset="0.0" />
                                    <GradientStop Color="#5AA5D0" Offset="0.5" />
                                    <GradientStop Color="#4E97C2" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                
                                <Border Height="20" VerticalAlignment="Top" CornerRadius="4,4,0,0" Margin="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#99FFFFFF" Offset="0.0" /> <GradientStop Color="#00FFFFFF" Offset="1.0" /> </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ContentPresenter.Effect>
                                        <DropShadowEffect Color="#205070" BlurRadius="2" ShadowDepth="1" Direction="315" Opacity="0.8" />
                                    </ContentPresenter.Effect>
                                </ContentPresenter>
                                
                            </Grid>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    </Window.Resources>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Content="시스템" FontSize="17" Foreground="White" Style="{StaticResource Button1}" />
        <Button Content="1 단" Style="{StaticResource StepButton}" Margin="20,0,0,0" />
        <Button Content="2 단" Style="{StaticResource StepButton}" Margin="20,0,0,0" />
    </StackPanel>
</Window>
