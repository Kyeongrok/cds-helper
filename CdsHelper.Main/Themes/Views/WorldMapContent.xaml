<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:CdsHelper.Main.UI.Views">

    <Style TargetType="{x:Type views:WorldMapContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:WorldMapContent}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="WORLD.CDS 세계지도 뷰어" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                        <!-- Toolbar -->
                        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                            <Button x:Name="PART_BtnOpen" Content="파일 열기" Padding="8,4" Margin="0,0,6,0"/>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                            <Button x:Name="PART_BtnZoomIn" Content="+" Width="28" Height="28" FontSize="16" FontWeight="Bold" Margin="4,0,2,0" ToolTip="확대"/>
                            <Button x:Name="PART_BtnZoomOut" Content="-" Width="28" Height="28" FontSize="16" FontWeight="Bold" Margin="2,0,2,0" ToolTip="축소"/>
                            <Button x:Name="PART_BtnZoomReset" Content="1:1" Height="28" Padding="6,0" Margin="2,0,6,0" ToolTip="원본 크기"/>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                            <CheckBox x:Name="PART_ShowCoast" Content="해안선 상세" VerticalAlignment="Center" Margin="6,0,8,0" IsChecked="True"/>
                            <CheckBox x:Name="PART_ShowWind" Content="해류/바람" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="PART_ShowDiscoveries" Content="발견물" VerticalAlignment="Center" Margin="0,0,8,0" IsChecked="True"/>
                            <CheckBox x:Name="PART_ShowCityLabels" Content="도시명" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="PART_HideFound" Content="미발견만" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="PART_ShowSpeed" Content="속도" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="이동 경로에 구간 속도 표시"/>
                            <TextBlock Text="자동스크롤:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox x:Name="PART_AutoScrollThreshold" VerticalAlignment="Center" Width="80" Margin="0,0,8,0"
                                      ToolTip="마커가 중심에서 이 비율만큼 벗어나면 스크롤">
                                <ComboBoxItem Content="30%" Tag="0.3"/>
                                <ComboBoxItem Content="50%" Tag="0.5"/>
                                <ComboBoxItem Content="70%" Tag="0.7"/>
                                <ComboBoxItem Content="90%" Tag="0.9"/>
                            </ComboBox>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                            <Button x:Name="PART_BtnLeaveCity" Content="탐험 떠나기" Height="28" Padding="8,0" Margin="0,0,4,0" ToolTip="도시에서 성문을 통해 탐험을 떠남"/>
                            <Button x:Name="PART_BtnTrackCoordinate" Content="좌표 추적" Height="28" Padding="8,0" Margin="0,0,4,0" ToolTip="게임 화면에서 좌표를 인식하여 지도에 표시"/>
                            <Button x:Name="PART_BtnClearTrail" Content="경로 지우기" Height="28" Padding="8,0" Margin="0,0,4,0" ToolTip="이동 경로 삭제"/>
                            <Button x:Name="PART_BtnSaveTrail" Content="경로 저장" Height="28" Padding="8,0" Margin="0,0,4,0" ToolTip="이동 경로를 파일로 저장"/>
                            <Button x:Name="PART_BtnLoadTrail" Content="경로 불러오기" Height="28" Padding="8,0" Margin="0,0,4,0" ToolTip="저장된 경로 불러오기"/>
                            <Button x:Name="PART_BtnCenterPosition" Content="◎" Width="28" Height="28" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" ToolTip="내 위치로 이동"/>
                            <TextBlock x:Name="PART_TxtCurrentCoordinate" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold" Margin="0,0,8,0"/>
                            <Button x:Name="PART_BtnStopNav" Content="자동이동 중지" Height="28" Padding="8,0" Margin="0,0,6,0"
                                    Background="#DC3545" Foreground="White" FontWeight="Bold" Visibility="Collapsed"/>
                            <TextBlock x:Name="PART_TxtNavStatus" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0,0,8,0"/>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                            <TextBlock x:Name="PART_Status" VerticalAlignment="Center" Foreground="Gray" Margin="6,0,0,0"/>
                        </WrapPanel>

                        <!-- Map display -->
                        <Border Grid.Row="2" BorderBrush="#555" BorderThickness="1" Background="#111">
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Grid x:Name="PART_MapGrid">
                                    <Image x:Name="PART_MapImage"
                                           Stretch="None"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True"/>
                                    <Canvas x:Name="PART_OverlayCanvas" Background="Transparent" IsHitTestVisible="True"
                                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>

                        <!-- Zoom label -->
                        <TextBlock x:Name="PART_ZoomLabel" Grid.Row="2"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,12,8" Padding="4,2"
                                   Background="#AA000000" Foreground="White"
                                   FontFamily="Consolas" FontSize="12"
                                   Text="x2.0"/>

                        <!-- Cell info bar -->
                        <Border Grid.Row="3" Background="#222" Padding="6,4" Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="PART_CellInfo" Foreground="#CCC" FontFamily="Consolas" FontSize="12"
                                           Text="마우스를 지도 위에 올리면 셀 정보가 표시됩니다"/>
                                <TextBlock Grid.Column="1" x:Name="PART_TxtEventStatus" Foreground="#FFD54F"
                                           FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
