<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:CdsHelper.Main.UI.Views">

    <Style TargetType="{x:Type views:MapContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:MapContent}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 상단 컨트롤 -->
                        <StackPanel Grid.Row="0" Margin="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="대항해시대3 발견물 지도" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Button x:Name="PART_BtnZoomReset" Content="원본" Width="60" Height="30" Margin="20,0,0,0" />
                                <CheckBox x:Name="PART_ChkShowCityLabels" Content="도시명 표시"
                                          VerticalAlignment="Center" Margin="20,0,0,0" IsChecked="False" />
                                <CheckBox x:Name="PART_ChkShowCoordinates" Content="좌표 표시"
                                          VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="False" />
                                <CheckBox x:Name="PART_ChkShowCulturalSpheres" Content="문화권 표시"
                                          VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="False" />
                                <CheckBox x:Name="PART_ChkShowShipyards" Content="조선소 표시"
                                          VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="False" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Button x:Name="PART_BtnTrackCoordinate" Content="좌표 추적"
                                        Width="80" Height="25" />
                                <Button x:Name="PART_BtnClearTrail" Content="경로 지우기"
                                        Width="80" Height="25" Margin="5,0,0,0" />

                                <!-- 자동이동 -->
                                <Border Margin="15,0,0,0" BorderBrush="#CCC" BorderThickness="1" CornerRadius="3"
                                        Padding="5,2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="목적지" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <ComboBox x:Name="PART_CmbNavLatDir" Width="55" Height="22" SelectedIndex="0">
                                            <ComboBoxItem Content="북위" />
                                            <ComboBoxItem Content="남위" />
                                        </ComboBox>
                                        <TextBox x:Name="PART_TxtNavLat" Width="35" Height="22" Margin="3,0,0,0"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                        <ComboBox x:Name="PART_CmbNavLonDir" Width="55" Height="22" Margin="5,0,0,0" SelectedIndex="0">
                                            <ComboBoxItem Content="동경" />
                                            <ComboBoxItem Content="서경" />
                                        </ComboBox>
                                        <TextBox x:Name="PART_TxtNavLon" Width="35" Height="22" Margin="3,0,0,0"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                        <Button x:Name="PART_BtnStartNav" Content="이동" Width="55" Height="22" Margin="5,0,0,0" />
                                        <Button x:Name="PART_BtnStopNav" Content="중지" Width="55" Height="22" Margin="3,0,0,0"
                                                Visibility="Collapsed" />
                                        <TextBlock x:Name="PART_TxtNavStatus" Text="" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" FontFamily="Consolas" Foreground="Blue" />
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="PART_TxtCurrentCoordinate" Text="" VerticalAlignment="Center"
                                           Margin="10,0,0,0" FontFamily="Consolas" Foreground="Red" FontWeight="Bold" />
                                <TextBlock x:Name="PART_TxtCenterPosition" Text="중심: -" VerticalAlignment="Center"
                                           Margin="15,0,0,0" FontFamily="Consolas" Foreground="#104F89" FontWeight="Bold" />
                                <TextBlock x:Name="PART_TxtMapCoordinates" Text="마우스: -" VerticalAlignment="Center"
                                           Margin="15,0,0,0" FontFamily="Consolas" Foreground="Gray" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 지도 영역 (경도 눈금 + 위도 눈금 + 지도) -->
                        <Grid Grid.Row="1" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <!-- 경도 눈금 (상단) -->
                            <Canvas x:Name="PART_LongitudeScale" Grid.Row="0" Grid.Column="0"
                                    Background="#F0F0F0" ClipToBounds="True"/>

                            <!-- 위도 눈금 (우측) -->
                            <Canvas x:Name="PART_LatitudeScale" Grid.Row="1" Grid.Column="1"
                                    Background="#F0F0F0" ClipToBounds="True"/>

                            <!-- 지도 이미지 -->
                            <ScrollViewer Grid.Row="1" Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          x:Name="PART_MapScrollViewer">
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Image x:Name="PART_ImgMap"
                                           Stretch="None"
                                           RenderTransformOrigin="0,0">
                                        <Image.LayoutTransform>
                                            <ScaleTransform x:Name="PART_MapScaleTransform" ScaleX="1" ScaleY="1" />
                                        </Image.LayoutTransform>
                                    </Image>
                                    <Canvas x:Name="PART_MapCanvas"
                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                            IsHitTestVisible="True"
                                            Background="Transparent">
                                        <Canvas.LayoutTransform>
                                            <ScaleTransform x:Name="PART_CanvasScaleTransform" ScaleX="1" ScaleY="1" />
                                        </Canvas.LayoutTransform>
                                    </Canvas>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
