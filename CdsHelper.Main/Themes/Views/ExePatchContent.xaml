<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:CdsHelper.Main.UI.Views"
                    xmlns:vm="clr-namespace:CdsHelper.Main.Local.ViewModels"
                    xmlns:units="clr-namespace:CdsHelper.Support.UI.Units;assembly=CdsHelper.Support">

    <Style TargetType="{x:Type views:ExePatchContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:ExePatchContent}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="대항해시대2 인물 목록 (CDS_95.EXE)" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="대화만 가능한 인물을 고용 가능하게 패치합니다" Foreground="Gray"/>
                        </StackPanel>

                        <!-- 파일 경로 및 버튼 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="파일: " VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ExeFilePath}" VerticalAlignment="Center" Foreground="#1976D2" Margin="0,0,20,0"/>
                            <Button Content="파일 선택" Command="{Binding BrowseFileCommand}"
                                    Width="80" Height="28" Margin="0,0,10,0"/>
                            <Button Content="새로고침" Command="{Binding RefreshCommand}"
                                    Width="80" Height="28" Margin="0,0,10,0"/>
                            <Button Content="원본 복원" Command="{Binding RestoreOriginalCommand}"
                                    Width="100" Height="28"
                                    Background="#FF9800" Foreground="White" BorderThickness="0"/>
                        </StackPanel>

                        <!-- 커스텀 패치 -->
                        <Border Grid.Row="5" Background="#F5F5F5" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="커스텀 패치" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                                    <ToggleButton x:Name="PART_RegisterToggle" Content="등록하기"
                                                  Width="80" Height="26" Margin="0,0,15,0" Cursor="Hand"/>
                                    <Button Content="저장(위치 지정)" Command="{Binding SaveCustomPatchesCommand}"
                                            Width="100" Height="26" Margin="0,0,5,0"/>
                                    <Button Content="불러오기" Command="{Binding LoadCustomPatchesCommand}"
                                            Width="80" Height="26" Margin="0,0,5,0"/>
                                    <!-- 내보내기: 체크된 항목이 하나라도 있을 때만 표시 -->
                                    <Button Content="내보내기" Command="{Binding ExportSelectedCustomPatchesCommand}"
                                            Width="80" Height="26"
                                            Background="#1976D2" Foreground="White" BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAnyChecked}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Text="입력/수정 시 자동 저장됩니다. 체크 후 [내보내기]로 선택 항목만 저장"
                                               VerticalAlignment="Center" Foreground="Gray" Margin="15,0,0,0"/>
                                </StackPanel>

                                <!-- 입력 영역 : '등록하기' 토글 시에만 표시 (2줄) -->
                                <StackPanel Margin="0,0,0,6">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=PART_RegisterToggle}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- 1줄: 이름 / 주소 / 바이트 / 범위 / + -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="이름" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding NewPatchName, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="270" Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="주소(hex)" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding NewPatchAddress, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="90" Height="26" FontFamily="Consolas" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="바이트" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                                        <ComboBox ItemsSource="{x:Static vm:CustomPatchItem.ByteSizeOptions}"
                                                  SelectedItem="{Binding NewPatchByteSize}"
                                                  Width="50" Height="26" Margin="0,0,10,0"/>
                                        <Button Content="+" Command="{Binding AddCustomPatchCommand}"
                                                Width="32" Height="26" FontWeight="Bold" FontSize="16"
                                                Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>

                                    <!-- 2줄: 설명 (가로 전체로 길게) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="설명" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewPatchDescription, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="26" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- 커스텀 패치 목록 -->
                                <units:CdsDataGrid x:Name="PART_CustomPatchGrid"
                                                  ItemsSource="{Binding CustomPatches}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  MaxHeight="180">
                                    <!-- 행 선택 시 색이 바뀌지 않도록 RowStyle/CellStyle 재정의 -->
                                    <units:CdsDataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                        </Style>
                                    </units:CdsDataGrid.RowStyle>
                                    <units:CdsDataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}" Padding="8,4">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </units:CdsDataGrid.CellStyle>
                                    <units:CdsDataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="34">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="이름" Width="200">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                             BorderThickness="0" Background="Transparent" Padding="2,0"
                                                             VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="설명" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <!-- 평소엔 한 줄로 말줄임 표시, 클릭하면 팝업에서 전체 내용 보기/편집 -->
                                                        <ToggleButton x:Name="DescToggle" Cursor="Hand"
                                                                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                      ToolTip="클릭하면 전체 설명 보기/편집">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent" Padding="2,0">
                                                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                            <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"/>
                                                        </ToggleButton>
                                                        <Popup IsOpen="{Binding IsChecked, ElementName=DescToggle}"
                                                               PlacementTarget="{Binding ElementName=DescToggle}"
                                                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                                            <Border Background="White" BorderBrush="#1A6BB5" BorderThickness="1"
                                                                    CornerRadius="4" Padding="6" MinWidth="260" MaxWidth="420">
                                                                <Border.Effect>
                                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                                                </Border.Effect>
                                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                                         TextWrapping="Wrap" AcceptsReturn="True"
                                                                         BorderThickness="0" Background="Transparent"
                                                                         MaxHeight="220" VerticalScrollBarVisibility="Auto"/>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="주소" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding AddressHex, UpdateSourceTrigger=LostFocus}"
                                                             FontFamily="Consolas" BorderThickness="0" Background="Transparent" Padding="2,0"
                                                             VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="값" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=LostFocus}" Tag="ValueCell"
                                                             FontWeight="Bold" TextAlignment="Center"
                                                             Foreground="Black" Background="White"
                                                             BorderBrush="#BBBBBB" BorderThickness="1"
                                                             Padding="2,1" Margin="2" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Width="24" Height="22"
                                                            Command="{Binding DataContext.RemoveCustomPatchCommand, RelativeSource={RelativeSource AncestorType={x:Type views:ExePatchContent}}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#F44336" Foreground="White" BorderThickness="0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- 수정: 클릭하면 전체 항목 편집 팝업 -->
                                        <DataGridTemplateColumn Header="" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <ToggleButton x:Name="EditToggle" Content="수정" Cursor="Hand"
                                                                      Width="48" Height="22"
                                                                      Background="#1976D2" Foreground="White" BorderThickness="0"/>
                                                        <Popup IsOpen="{Binding IsChecked, ElementName=EditToggle}"
                                                               PlacementTarget="{Binding ElementName=EditToggle}"
                                                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                                            <Border Background="White" BorderBrush="#1A6BB5" BorderThickness="1"
                                                                    CornerRadius="4" Padding="10" Width="320">
                                                                <Border.Effect>
                                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                                                </Border.Effect>
                                                                <StackPanel>
                                                                    <TextBlock Text="패치 수정" FontWeight="Bold" Margin="0,0,0,8"/>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="64"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>

                                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="이름" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,6,4"/>
                                                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,4"/>

                                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="설명" VerticalAlignment="Top" Foreground="Gray" Margin="0,4,6,4"/>
                                                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44" MaxHeight="120"
                                                                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>

                                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="주소(hex)" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,6,4"/>
                                                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AddressHex, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" Margin="0,0,0,4"/>

                                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="바이트" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,6,4"/>
                                                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{x:Static vm:CustomPatchItem.ByteSizeOptions}"
                                                                                  SelectedItem="{Binding ByteSize}" HorizontalAlignment="Left" Width="60" Margin="0,0,0,4"/>

                                                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="값" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,6,0"/>
                                                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=LostFocus}" FontWeight="Bold" HorizontalAlignment="Left" Width="110"/>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </units:CdsDataGrid.Columns>
                                </units:CdsDataGrid>
                            </StackPanel>
                        </Border>

                        <!-- 항해사 등장/고용 수정 제목 -->
                        <StackPanel Grid.Row="6" Margin="2,4,0,6">
                            <TextBlock Text="항해사 등장여부 / 고용 수정" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="출생연도·고용 가능 여부를 수정합니다 (대화만 가능한 인물을 고용 가능하게)"
                                       Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- 데이터 그리드 -->
                        <units:CdsDataGrid Grid.Row="7"
                                          ItemsSource="{Binding Characters}"
                                          AutoGenerateColumns="False">
                            <units:CdsDataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HireStatusValue}" Value="2">
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HireStatusValue}" Value="1">
                                            <Setter Property="Background" Value="#FFF3E0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </units:CdsDataGrid.RowStyle>
                            <units:CdsDataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="35" IsReadOnly="True"/>
                                <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="160" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="출생" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding BirthYear, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="0" Background="Transparent"
                                                     Padding="2,0" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="고용" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{x:Static vm:HireStatusOption.Options}"
                                                      SelectedValue="{Binding HireStatusValue, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Display"
                                                      BorderThickness="0"
                                                      Background="Transparent"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="패치주소" Binding="{Binding PatchAddress}" Width="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </units:CdsDataGrid.Columns>
                        </units:CdsDataGrid>

                        <!-- 상태 바 -->
                        <Border Grid.Row="8" Background="#F5F5F5" Padding="10,5" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusText}" />
                                <TextBlock Text=" | " Foreground="Gray" Margin="10,0"/>
                                <TextBlock Text="총 "/>
                                <TextBlock Text="{Binding TotalCount}" FontWeight="Bold"/>
                                <TextBlock Text="명, 대화만: "/>
                                <TextBlock Text="{Binding TalkOnlyCount}" FontWeight="Bold" Foreground="#E65100"/>
                                <TextBlock Text="명"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
