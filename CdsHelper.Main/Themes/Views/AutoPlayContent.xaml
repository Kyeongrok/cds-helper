<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:CdsHelper.Main.UI.Views">

    <Style TargetType="{x:Type views:AutoPlayContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:AutoPlayContent}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 + 시작/중지 -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="자동플레이" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="시작"
                                        Command="{Binding StartCommand}"
                                        Padding="20,6" MinWidth="80" Margin="0,0,5,0"/>
                                <Button Content="중지"
                                        Command="{Binding StopCommand}"
                                        Padding="20,6" MinWidth="80"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- 게임 연결 상태 -->
                        <GroupBox Grid.Row="1" Header="게임 상태" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="게임 실행:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#FF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                                        <Setter Property="Fill" Value="#44BB44"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding GameRunningDisplay}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="현재 장면:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GameSceneIcon}" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding GameSceneDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- 템플릿 캡처 -->
                        <GroupBox Grid.Row="2" Header="템플릿 캡처 (현재 게임 화면을 장면 템플릿으로 저장)" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="장면:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CaptureScenes}"
                                          SelectedItem="{Binding SelectedCaptureScene}"
                                          DisplayMemberPath="DisplayName"
                                          Padding="5,3"/>
                                <Button Grid.Column="3"
                                        Content="캡처 저장"
                                        Command="{Binding CaptureTemplateCommand}"
                                        Padding="15,5" MinWidth="90"/>
                            </Grid>
                        </GroupBox>

                        <!-- 목적지 선택 -->
                        <GroupBox Grid.Row="3" Header="자동 항해" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="목적지:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding Cities}"
                                          SelectedItem="{Binding SelectedCity}"
                                          DisplayMemberPath="Name"
                                          Padding="5,3"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="상태:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="목적지:" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DestinationDisplay}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="현재 좌표:" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentLatDisplay}" Margin="0,0,10,0"/>
                                    <TextBlock Text=",  "/>
                                    <TextBlock Text="{Binding CurrentLonDisplay}" Margin="10,0,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="방위각:" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding BearingDisplay}" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <!-- 좌표 인식 (TorchSharp) -->
                        <GroupBox Grid.Row="4" Header="좌표 인식 (위도/경도 학습)" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <!-- 1단계: 캡처 + 수집 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="스크린샷 캡처"
                                            Command="{Binding CapturePreviewCommand}"
                                            Padding="10,4" MinWidth="100" Margin="0,0,5,0"/>
                                    <Button Content="폴더 열기"
                                            Command="{Binding OpenCoordDataFolderCommand}"
                                            Padding="10,4" MinWidth="70" Margin="0,0,5,0"/>
                                    <Button Content="수집 시작"
                                            Command="{Binding StartCollectCoordsCommand}"
                                            Padding="10,4" MinWidth="80" Margin="0,0,5,0"
                                            Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                    <Button Content="수집 중지"
                                            Command="{Binding StopCollectCoordsCommand}"
                                            Padding="10,4" MinWidth="80" Margin="0,0,5,0"
                                            Background="#F44336" Foreground="White" BorderThickness="0"/>
                                </StackPanel>

                                <!-- 2단계: 라벨링 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="자동 라벨링 (OCR)"
                                            Command="{Binding AutoLabelCoordsCommand}"
                                            Padding="10,4" MinWidth="120" Margin="0,0,10,0"
                                            Background="#FF9800" Foreground="White" BorderThickness="0"/>
                                    <TextBlock Text="수동:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding CoordLabelInput, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120" Height="26" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Content="추가"
                                            Command="{Binding AddCoordLabelCommand}"
                                            Padding="10,4" MinWidth="50" Margin="0,0,8,0"/>
                                    <TextBlock Text="(0,38,1,10 = 북위38 서경10)"
                                               VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                                </StackPanel>

                                <!-- 3단계: 학습 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="에포크:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding CoordTrainEpochs, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" Height="26" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Content="모델 학습"
                                            Command="{Binding TrainCoordModelCommand}"
                                            Padding="15,4" MinWidth="90" Margin="0,0,10,0"
                                            Background="#2196F3" Foreground="White" BorderThickness="0"/>
                                    <TextBlock Text="{Binding CoordStatusText}" VerticalAlignment="Center" Foreground="#1976D2"/>
                                </StackPanel>

                                <!-- 4단계: 실시간 인식 -->
                                <Border Background="#E8F5E9" CornerRadius="4" Padding="8,4" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding RecognizeInterval, UpdateSourceTrigger=PropertyChanged}"
                                                Width="45" Height="26" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="ms" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Gray"/>
                                        <Button Content="인식 시작"
                                                Command="{Binding StartRecognizeCommand}"
                                                Padding="10,4" MinWidth="80" Margin="0,0,5,0"
                                                Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                        <Button Content="인식 중지"
                                                Command="{Binding StopRecognizeCommand}"
                                                Padding="10,4" MinWidth="80" Margin="0,0,12,0"
                                                Background="#F44336" Foreground="White" BorderThickness="0"/>
                                        <TextBlock Text="현재 좌표:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RecognizedCoordText}" VerticalAlignment="Center"
                                                   FontSize="14" FontWeight="Bold" Foreground="#1B5E20"/>
                                    </StackPanel>
                                </Border>

                                <!-- 5단계: 자동 항해 -->
                                <Border Background="#E3F2FD" CornerRadius="4" Padding="8,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="목표:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <ComboBox SelectedIndex="{Binding TargetIsNorth, Converter={x:Static views:AutoPlayContent.BoolToIndexConverter}}"
                                                      Width="55" Height="26" Margin="0,0,4,0">
                                                <ComboBoxItem Content="북위"/>
                                                <ComboBoxItem Content="남위"/>
                                            </ComboBox>
                                            <TextBox Text="{Binding TargetLat, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="40" Height="26" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox SelectedIndex="{Binding TargetIsEast, Converter={x:Static views:AutoPlayContent.BoolToIndexConverter}}"
                                                      Width="55" Height="26" Margin="0,0,4,0">
                                                <ComboBoxItem Content="동경"/>
                                                <ComboBoxItem Content="서경"/>
                                            </ComboBox>
                                            <TextBox Text="{Binding TargetLon, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="40" Height="26" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                            <Button Content="항해 시작"
                                                    Command="{Binding StartNavCommand}"
                                                    Padding="10,4" MinWidth="80" Margin="0,0,5,0"
                                                    Background="#1565C0" Foreground="White" BorderThickness="0"/>
                                            <Button Content="항해 중지"
                                                    Command="{Binding StopNavCommand}"
                                                    Padding="10,4" MinWidth="80"
                                                    Background="#F44336" Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding NavStatusText}" Foreground="#0D47A1" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <!-- 해도 분석 -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="해도 분석 테스트"
                                            Command="{Binding TestSeaMapCommand}"
                                            Padding="10,4" MinWidth="110" Margin="0,0,8,0"/>
                                    <TextBlock Text="게임 화면의 바다/육지/배 분류 결과를 이미지로 저장"
                                               VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- 능력치 리롤 -->
                        <GroupBox Grid.Row="5" Header="능력치 리롤 (사냥꾼 클릭)" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <!-- 목표치 (0=무시) -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="체력" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetHp, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="2" Text="지력" VerticalAlignment="Center" Margin="6,0,3,0" FontWeight="SemiBold"/>
                                    <TextBox Grid.Column="3" Text="{Binding TargetInt, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="4" Text="무력" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="5" Text="{Binding TargetStr, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="6" Text="매력" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="7" Text="{Binding TargetCha, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="8" Text="운" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="9" Text="{Binding TargetLuck, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="10" Text="보너스" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="11" Text="{Binding TargetBonus, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="12" Text="(0=무시)" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" FontSize="11"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="시도:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding RerollAttempts}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,12,0"/>
                                    <TextBlock Text="최대:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,3,0"/>
                                    <TextBox Text="{Binding MaxAttempts, UpdateSourceTrigger=PropertyChanged}"
                                             TextAlignment="Center" VerticalContentAlignment="Center" Height="24" Width="50" Margin="0,0,3,0"/>
                                    <TextBlock Text="회" VerticalAlignment="Center" Foreground="Gray"/>
                                </StackPanel>

                                <!-- 버튼 행 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="시작" Command="{Binding StartRerollCommand}"
                                            Padding="15,4" MinWidth="70" Margin="0,0,5,0"
                                            Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                    <Button Content="중지" Command="{Binding StopRerollCommand}"
                                            Padding="15,4" MinWidth="70" Margin="0,0,5,0"
                                            Background="#F44336" Foreground="White" BorderThickness="0"/>
                                    <Button Content="테스트 인식" Command="{Binding TestReadStatCommand}"
                                            Padding="10,4" MinWidth="90" Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding RerollStatusText}" VerticalAlignment="Center" Foreground="#1976D2"/>
                                </StackPanel>

                                <!-- 숫자 학습 -->
                                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="숫자 학습:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding LearnStatValues, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="160" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                        <Button Content="학습" Command="{Binding LearnDigitsCommand}"
                                                Padding="15,4" MinWidth="60" Margin="0,0,10,0"
                                                Background="#2196F3" Foreground="White" BorderThickness="0"/>
                                        <TextBlock Text="화면의 능력치 입력 (체력,지력,무력,매력,운,보너스)"
                                                   VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <!-- 로그 -->
                        <GroupBox Grid.Row="6" Header="로그" Padding="5">
                            <ListBox ItemsSource="{Binding LogMessages}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
