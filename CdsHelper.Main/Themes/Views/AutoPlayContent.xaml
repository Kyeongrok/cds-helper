<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:CdsHelper.Main.UI.Views">

    <Style TargetType="{x:Type views:AutoPlayContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:AutoPlayContent}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 + 시작/중지 -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="자동플레이" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="시작"
                                        Command="{Binding StartCommand}"
                                        Padding="20,6" MinWidth="80" Margin="0,0,5,0"/>
                                <Button Content="중지"
                                        Command="{Binding StopCommand}"
                                        Padding="20,6" MinWidth="80"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- 능력치 리롤 -->
                        <GroupBox Grid.Row="1" Header="능력치 리롤 (사냥꾼 클릭)" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <!-- 숫자 학습 -->
                                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="자동 학습" Command="{Binding AutoLearnDigitsCommand}"
                                                Padding="10,4" MinWidth="80" Margin="0,0,5,0"
                                                Background="#FF9800" Foreground="White" BorderThickness="0"/>
                                        <Button Content="초기화" Command="{Binding ClearTemplatesCommand}"
                                                Padding="10,4" MinWidth="60" Margin="0,0,5,0"/>
                                        <Button Content="테스트 인식" Command="{Binding TestReadStatCommand}"
                                                Padding="10,4" MinWidth="90" Margin="0,0,15,0"/>
                                        <ItemsControl Margin="0,0,10,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="0">
                                                    <Image Source="{Binding Digit0}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="1">
                                                    <Image Source="{Binding Digit1}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="2">
                                                    <Image Source="{Binding Digit2}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="3">
                                                    <Image Source="{Binding Digit3}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="4">
                                                    <Image Source="{Binding Digit4}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="5">
                                                    <Image Source="{Binding Digit5}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="6">
                                                    <Image Source="{Binding Digit6}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="7">
                                                    <Image Source="{Binding Digit7}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="8">
                                                    <Image Source="{Binding Digit8}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                                <Border Width="20" Height="20" BorderBrush="#CCC" BorderThickness="1" Margin="1,0" ToolTip="9">
                                                    <Image Source="{Binding Digit9}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                </Border>
                                            </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- 목표치 (0=무시) -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="체력" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetHp, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="2" Text="지력" VerticalAlignment="Center" Margin="6,0,3,0" FontWeight="SemiBold"/>
                                    <TextBox Grid.Column="3" Text="{Binding TargetInt, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="4" Text="무력" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="5" Text="{Binding TargetStr, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="6" Text="매력" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="7" Text="{Binding TargetCha, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="8" Text="운" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="9" Text="{Binding TargetLuck, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="10" Text="보너스" VerticalAlignment="Center" Margin="6,0,3,0"/>
                                    <TextBox Grid.Column="11" Text="{Binding TargetBonus, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Height="24"/>
                                    <TextBlock Grid.Column="12" Text="(0=무시)" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" FontSize="11"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="시도:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding RerollAttempts}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,12,0"/>
                                    <TextBlock Text="최대:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,3,0"/>
                                    <TextBox Text="{Binding MaxAttempts, UpdateSourceTrigger=PropertyChanged}"
                                             TextAlignment="Center" VerticalContentAlignment="Center" Height="24" Width="50" Margin="0,0,3,0"/>
                                    <TextBlock Text="회" VerticalAlignment="Center" Foreground="Gray"/>
                                </StackPanel>

                                <!-- 버튼 행 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="시작" Command="{Binding StartRerollCommand}"
                                            Padding="15,4" MinWidth="70" Margin="0,0,5,0"
                                            Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                    <Button Content="중지" Command="{Binding StopRerollCommand}"
                                            Padding="15,4" MinWidth="70" Margin="0,0,10,0"
                                            Background="#F44336" Foreground="White" BorderThickness="0"/>
                                    <TextBlock Text="{Binding RerollStatusText}" VerticalAlignment="Center" Foreground="#1976D2"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- 로그 -->
                        <GroupBox Grid.Row="2" Header="로그" Padding="5">
                            <ListBox ItemsSource="{Binding LogMessages}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     Height="350"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
